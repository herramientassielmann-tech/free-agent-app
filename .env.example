# Clave secreta para firmar JWT (genera con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI Whisper API (para transcripción de TikTok e Instagram)
OPENAI_API_KEY=sk-proj-...

# Cuenta del administrador (se crea automáticamente al arrancar si no existe)
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=cambia-esta-contrasena

# Base de datos (Supabase PostgreSQL recomendado)
DATABASE_URL=postgresql://postgres.[ID]:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres?sslmode=require

# Entorno (development / production)
ENV=development
